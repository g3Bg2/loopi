{
  "name": "GitHub Issue Tracker",
  "description": "Lists open issues from a repo, filters critical ones, and creates a summary comment",
  "nodes": [
    {
      "id": "node-1",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "step-1",
          "type": "githubListIssues",
          "description": "List open issues",
          "credentialId": "my-github-token",
          "owner": "myorg",
          "repo": "myproject",
          "state": "open",
          "labels": "bug",
          "perPage": 20,
          "storeKey": "issues"
        }
      },
      "position": { "x": 0, "y": 0 }
    },
    {
      "id": "node-2",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "step-2",
          "type": "filterArray",
          "description": "Filter critical issues",
          "array": "{{issues}}",
          "condition": "item.labels.some(l => l.name === 'critical')",
          "storeKey": "criticalIssues"
        }
      },
      "position": { "x": 0, "y": 100 }
    },
    {
      "id": "node-3",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "step-3",
          "type": "githubCreateIssue",
          "description": "Create summary issue",
          "credentialId": "my-github-token",
          "owner": "myorg",
          "repo": "myproject",
          "title": "Weekly Critical Bug Summary",
          "body": "Found {{criticalIssues.length}} critical issues this week.",
          "labels": ["summary", "automated"],
          "storeKey": "summaryIssue"
        }
      },
      "position": { "x": 0, "y": 200 }
    }
  ],
  "edges": [
    { "id": "e1-2", "source": "node-1", "target": "node-2" },
    { "id": "e2-3", "source": "node-2", "target": "node-3" }
  ]
}
